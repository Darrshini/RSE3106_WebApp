# NavAssist Environment Variables
# Copy this file to .env ONLY if you need to change a default below.
# .env is in .gitignore and will NEVER be committed to GitHub.
#
# No API keys are required: both models run locally (pedestrian.onnx in the
# browser, crossing_seg.onnx on the server) and map data comes from the keyless
# Overpass API. See the README.

PORT=3000
